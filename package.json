{
  "name": "glass-wizard-music-nft",
  "version": "1.0.0",
  "description": "Digital music making AI application linked to XRPL through NFT",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "demo": "node dist/index.js",
    "demo:xrpl": "DEMO_XRPL=true node dist/index.js",
    "build": "tsc",
    "test": "jest --testEnvironment node",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "xrpl",
    "nft",
    "music",
    "ai",
    "blockchain"
  ],
  "license": "MIT",
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "express": "^4.18.2",
    "xrpl": "^3.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1"
    }
  }
}
