# Glass Wizard – Environment Variables
# Copy this file to .env and fill in values before starting the server.
# All variables are optional; sensible defaults are shown below.

# ─── XRPL Network ────────────────────────────────────────────────────────────
# Which XRP Ledger network to connect to.
# Values: testnet | devnet | mainnet
# Use "testnet" (default) for development and testing with free tokens.
# Use "mainnet" for production with real XRP.
XRPL_NETWORK=testnet

# ─── HTTP Server ─────────────────────────────────────────────────────────────
# Port for the standalone Express server (npm start / npm run dev).
# Ignored on Vercel – Vercel manages its own port allocation.
PORT=3000

# ─── CLI Demo ────────────────────────────────────────────────────────────────
# Set to "true" to enable full XRPL wallet funding + NFT minting in the CLI
# demo (npm run demo:xrpl).  Leave unset or set to "false" to run the music
# generation demo only.
DEMO_XRPL=false
